# ─────────────────────────────────────────────────────────────
# Voyage — optional keys. The app runs fully WITHOUT any of these.
# With zero env vars: concierge uses the local rules engine,
# weather uses the no-key Open-Meteo source (falls back to seed).
# ─────────────────────────────────────────────────────────────

# Hugging Face Inference API token — powers the live AI concierge.
# Without it, the concierge silently uses the local rules-based engine.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: override the hosted instruct model used by the concierge proxy.
# Defaults to a Llama-3.x / Qwen instruct chat model.
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
